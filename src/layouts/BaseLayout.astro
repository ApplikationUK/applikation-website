---
import '../styles/global.css';
import { safeFetch } from '../sanity/client';
import { SITE_SETTINGS_QUERY } from '../sanity/queries';

export interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Growth & Innovation Partner — embedded, practical, results-driven.' } = Astro.props;

const settings = await safeFetch<any>(SITE_SETTINGS_QUERY, null);

const navLinks = settings?.navLinks ?? [
  { label: 'Services', href: '/#services', isCta: false },
  { label: 'Work', href: '/#work', isCta: false },
  { label: 'Process', href: '/#process', isCta: false },
  { label: 'About', href: '/#about', isCta: false },
  { label: "Let's talk →", href: '/#contact', isCta: true },
];

const footerTagline = settings?.footerTagline ?? 'Growth & Innovation Partner — embedded, practical, results-driven.';
const footerBookingStatus = settings?.footerBookingStatus ?? 'Booking Q3 · 2026';
const footerLocations = settings?.footerLocations ?? ['Isle of Man — IM1 1JA', 'Manchester — M1 7JR'];
const copyrightText = settings?.copyrightText ?? '© 2026 Applikation Limited';
const logoCarousel = settings?.logoCarousel ?? ['Annabel Karmel','ProvaRISK','Total Active Hub','Bioscore','Locus Security','Wellspace','Value for Venues','Optimise Your Marketing','Chlikk','Pocket Inspector','Olivier Mythodrama','Karmel & Co'];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
</head>
<body>

<nav id="main-nav" class="scrolled">
  <a href="/" class="nav-logo">
    <img src="/uploads/Logowhite.png" alt="Applikation" class="logo-wordmark" />
  </a>
  <ul class="nav-links">
    {navLinks.map((link: any) => (
      <li>
        <a href={link.href} class={link.isCta ? 'nav-cta' : ''}>
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<slot />

<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img src="/uploads/Logowhite.png" alt="Applikation" />
        </a>
        <p class="footer-tagline">{footerTagline}</p>
        <span class="footer-status"><span class="dot"></span> {footerBookingStatus}</span>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">// Services</div>
        <a href="/#services">AI Strategy</a>
        <a href="/#services">Product Development</a>
        <a href="/#services">Development Innovation</a>
        <a href="/#services">Process Automation</a>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">// Company</div>
        <a href="/#about">About</a>
        <a href="/#work">Work</a>
        <a href="/#process">Process</a>
        <a href="/#contact">Contact</a>
      </div>
      <div class="footer-col">
        <div class="footer-col-title">// Locations</div>
        {footerLocations.map((loc: string) => (
          <a href="#">{loc}</a>
        ))}
      </div>
    </div>
    <div class="footer-bottom">
      <span>{copyrightText}</span>
      <span>Made with care in the UK</span>
    </div>
  </div>
</footer>

<script src="/image-slot.js" is:inline></script>
<script>
  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    nav?.classList.add('scrolled');
  });
</script>
<script define:vars={{ logoCarousel }}>
  (function() {
    const track = document.getElementById('logo-track');
    if (!track) return;
    const double = [...logoCarousel, ...logoCarousel];
    track.innerHTML = double.map(name => `<div class="logo-item">${name}</div>`).join('');
  })();
</script>

</body>
</html>
