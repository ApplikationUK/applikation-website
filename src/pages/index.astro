      </a>

      <div class="insight-list">
        {sidebarPosts.map(post => (
          <a href={`/blog/${post.slug}`} class="insight-card" style="text-decoration:none;">
            <div class="insight-cat">// {post.data.category}</div>
            <h3 class="insight-card-title">{post.data.title}</h3>
            <p class="insight-card-excerpt">{post.data.excerpt}</p>
