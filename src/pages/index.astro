<script define:vars={{ caseStudiesData: caseStudies }}>
  // Hero canvas — connected node network
  (function() {
    const canvas = document.getElementById('hero-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let W, H, dots = [];
    function resize() { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight; }
    function initDots() {
      dots = [];
      const count = Math.min(60, Math.floor((W * H) / 18000));
      for (let i = 0; i < count; i++) {
        dots.push({ x: Math.random() * W, y: Math.random() * H, vx: (Math.random() - 0.5) * 0.18, vy: (Math.random() - 0.5) * 0.18, r: Math.random() * 1.2 + 0.4 });
      }
    }
    function draw() {
      ctx.clearRect(0, 0, W, H);
      for (let i = 0; i < dots.length; i++) {
        for (let j = i + 1; j < dots.length; j++) {
          const dx = dots[i].x - dots[j].x, dy = dots[i].y - dots[j].y;
          const dist = Math.sqrt(dx*dx + dy*dy);
          if (dist < 150) {
            ctx.beginPath(); ctx.moveTo(dots[i].x, dots[i].y); ctx.lineTo(dots[j].x, dots[j].y);
            ctx.strokeStyle = `rgba(255,255,255,${(1 - dist/150) * 0.12})`; ctx.lineWidth = 0.6; ctx.stroke();
          }
        }
      }
      for (const d of dots) {
        ctx.beginPath(); ctx.arc(d.x, d.y, d.r, 0, Math.PI*2);
        ctx.fillStyle = 'rgba(255,255,255,0.35)'; ctx.fill();
        d.x += d.vx; d.y += d.vy;
        if (d.x < 0 || d.x > W) d.vx *= -1;
        if (d.y < 0 || d.y > H) d.vy *= -1;
      }
      requestAnimationFrame(draw);
    }
    resize(); initDots(); draw();
    window.addEventListener('resize', () => { resize(); initDots(); });
  })();

  // Voices scroll
  (function() {
    const track = document.getElementById('voices-track');
    const prev = document.getElementById('voices-prev');
    const next = document.getElementById('voices-next');
    if (!track || !prev || !next) return;
    const amount = () => { const c = track.querySelector('.voice'); return c ? c.getBoundingClientRect().width : track.clientWidth * 0.8; };
    next.addEventListener('click', () => track.scrollBy({ left: amount(), behavior: 'smooth' }));
    prev.addEventListener('click', () => track.scrollBy({ left: -amount(), behavior: 'smooth' }));
  })();

  // Case study carousel
  function formatNum(str) {
    return str.replace(/([^\d.,]+)$/, '<span class="accent-color">$1</span>');
  }

  let activeIdx = 0;
  function renderCase(idx) {
    const cs = caseStudiesData[idx];
    const hasPage = cs.hasPage;
    const titleHtml = hasPage
      ? `<a href="/case-studies/${cs.slug}" class="cs-title-link"><h3 class="cs-title">${cs.title}</h3></a>`
      : `<h3 class="cs-title">${cs.title}</h3>`;
    const ctaHtml = hasPage
      ? `<a href="/case-studies/${cs.slug}" class="btn btn-primary" style="align-self:flex-start;">Read the case study <span class="arrow">→</span></a>`
      : `<a href="#contact" class="btn btn-primary" style="align-self:flex-start;">Discuss this project <span class="arrow">→</span></a>`;
    const visualHtml = hasPage
      ? `<a href="/case-studies/${cs.slug}" class="cs-visual cs-visual-link" aria-label="Read ${cs.title} case study">${cs.visualSvg}</a>`
      : `<div class="cs-visual">${cs.visualSvg}</div>`;
    document.getElementById('cs-featured').innerHTML = `
      ${visualHtml}
      <div class="cs-body">
        <div class="cs-tag">${cs.tag}</div>
        ${titleHtml}
        <p class="cs-desc">${cs.description}</p>
        <div class="cs-stats">
          ${cs.stats.map(s => `<div class="cs-stat"><div class="cs-stat-num">${formatNum(s.num)}</div><div class="cs-stat-label">${s.label}</div></div>`).join('')}
        </div>
        ${ctaHtml}
      </div>`;
    const dotsEl = document.getElementById('cs-dots');
    dotsEl.innerHTML = caseStudiesData.map((_, i) =>
      `<button class="cs-dot ${i===idx?'active':''}" data-i="${i}" aria-label="Case study ${i+1}"></button>`
    ).join('');
    dotsEl.querySelectorAll('[data-i]').forEach(el => {
      el.addEventListener('click', () => { activeIdx = parseInt(el.dataset.i); renderCase(activeIdx); });
    });
  }
  document.getElementById('cs-prev').addEventListener('click', () => { activeIdx = (activeIdx - 1 + caseStudiesData.length) % caseStudiesData.length; renderCase(activeIdx); });
  document.getElementById('cs-next').addEventListener('click', () => { activeIdx = (activeIdx + 1) % caseStudiesData.length; renderCase(activeIdx); });
  renderCase(0);

  // Contact form
  document.getElementById('contact-form').addEventListener('submit', function(e) {
    e.preventDefault();
    this.style.display = 'none';
    document.getElementById('form-success').classList.add('visible');
  });
</script>

</BaseLayout>
