            <rect width="700" height="280" fill="url(#ig-grid)"/>
            <circle cx="350" cy="140" r="120" fill="none" stroke="rgba(255,91,46,0.18)" stroke-width="1"/>
            <circle cx="350" cy="140" r="80" fill="none" stroke="rgba(255,91,46,0.28)" stroke-width="1"/>
            <circle cx="350" cy="140" r="40" fill="rgba(255,91,46,0.08)" stroke="rgba(255,91,46,0.5)" stroke-width="1.5"/>
            <text x="350" y="138" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="rgba(255,91,46,0.9)" font-weight="600">AI</text>
            <text x="350" y="155" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="rgba(255,91,46,0.5)">// in-business</text>
            <line x1="140" y1="60" x2="310" y2="140" stroke="rgba(255,91,46,0.15)" stroke-width="1" stroke-dasharray="4,3"/>
            <line x1="560" y1="60" x2="390" y2="140" stroke="rgba(255,91,46,0.15)" stroke-width="1" stroke-dasharray="4,3"/>
            <line x1="140" y1="220" x2="310" y2="140" stroke="rgba(255,91,46,0.15)" stroke-width="1" stroke-dasharray="4,3"/>
            <line x1="560" y1="220" x2="390" y2="140" stroke="rgba(255,91,46,0.15)" stroke-width="1" stroke-dasharray="4,3"/>
            <rect x="130" y="50" width="20" height="20" fill="rgba(255,255,255,0.12)"/>
            <rect x="550" y="50" width="20" height="20" fill="rgba(255,255,255,0.12)"/>
            <rect x="130" y="210" width="20" height="20" fill="rgba(255,255,255,0.12)"/>
            <rect x="550" y="210" width="20" height="20" fill="rgba(255,91,46,0.5)"/>
