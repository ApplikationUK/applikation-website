        </div>
        <div class="contact-detail">
          <div class="cd-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-7 8-13a8 8 0 0 0-16 0c0 6 8 13 8 13z"/><circle cx="12" cy="9" r="3"/></svg></div>
          <div>
            <div class="cd-label">// Isle of Man HQ</div>
            <div class="cd-value">Floor 2, 14 Athol St<br />Douglas, IM1 1JA</div>
          </div>
        </div>
        <div class="contact-detail">
          <div class="cd-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-7 8-13a8 8 0 0 0-16 0c0 6 8 13 8 13z"/><circle cx="12" cy="9" r="3"/></svg></div>
          <div>
            <div class="cd-label">// Manchester HQ</div>
            <div class="cd-value">Renold Building, SISTER<br />32a Altrincham St, M1 7JR</div>
          </div>
        </div>
        <div class="contact-detail">
          <div class="cd-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
          <div>
            <div class="cd-label">// Response</div>
