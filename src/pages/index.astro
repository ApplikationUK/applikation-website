          <p class="insight-feat-excerpt">{featuredPost.data.excerpt}</p>
          <div class="insight-meta">
            <span>{featuredPost.data.author}</span>
            <span class="insight-meta-sep"></span>
            <span>{formatDate(featuredPost.data.pubDate)}</span>
