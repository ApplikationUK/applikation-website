</section>

<!-- CONTACT -->
<section class="section contact on-dark" id="contact">
  <div class="contact-inner">
    <div class="contact-info-section">
      <div class="eyebrow on-dark"><span class="bar"></span><span class="num">07</span><span>Get in touch</span></div>
